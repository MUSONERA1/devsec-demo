# ==========================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ==========================================
# Copy this file to .env and update with production values
# NEVER commit actual .env files with real secrets to version control
# Use this as a reference for required production environment variables

# ==========================================
# DEPLOYMENT ENVIRONMENT
# ==========================================
# Set to 'production' for production deployments
DJANGO_ENV=production

# ==========================================
# SECRET KEY MANAGEMENT
# ==========================================
# CRITICAL: Generate a strong SECRET_KEY using:
# python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
# Must be at least 50 characters, use only alphanumeric and special characters
DJANGO_SECRET_KEY=your-long-random-secret-key-here-change-this-in-production

# ==========================================
# DEBUG MODE
# ==========================================
# CRITICAL: Must be False in production
# Never reveal stack traces or configuration details to attackers
DJANGO_DEBUG=False

# ==========================================
# ALLOWED HOSTS
# ==========================================
# Comma-separated list of allowed domain names
# Prevents Host Header Injection attacks
ALLOWED_HOSTS=example.com,www.example.com,api.example.com

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# Production: Use PostgreSQL or MySQL instead of SQLite
# SQLite is not recommended for production due to scalability limitations
DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_NAME=devsec_prod
DATABASE_USER=devsec_user
DATABASE_PASSWORD=strong-database-password-here
DATABASE_HOST=db.example.com
DATABASE_PORT=5432

# ==========================================
# EMAIL CONFIGURATION
# ==========================================
# Production: Must use SMTP backend
# Can use SendGrid, AWS SES, or your own mail server
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-app-specific-password
DEFAULT_FROM_EMAIL=noreply@example.com

# ==========================================
# CACHE CONFIGURATION
# ==========================================
# Production: Use Redis or Memcached for better performance
# Improves session management, cache, and brute-force protection
REDIS_URL=redis://cache.example.com:6379/0

# ==========================================
# SECURITY SETTINGS
# ==========================================
# HSTS: HTTP Strict Transport Security (1 year in seconds)
SECURE_HSTS_SECONDS=31536000

# ==========================================
# SESSION SECURITY
# ==========================================
# Session cookie age (in seconds): 1 hour = 3600
SESSION_COOKIE_AGE=3600

# ==========================================
# BRUTE-FORCE PROTECTION
# ==========================================
# Maximum failed login attempts before lockout
MAX_LOGIN_ATTEMPTS=5

# Lockout period (in seconds): 15 minutes = 900
LOCKOUT_PERIOD=900

# ==========================================
# STATIC FILES
# ==========================================
# Ensure static files are collected before deployment
# python manage.py collectstatic --noinput

# ==========================================
# LOGGING
# ==========================================
# Logs are written to:
# - logs/django.log - Application logs
# - logs/security.log - Security-related warnings and errors
# Ensure logs directory and files have appropriate permissions
# Use log rotation to manage disk space
